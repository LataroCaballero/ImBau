# Dependencies
node_modules/

# Build outputs
.next/
dist/
.turbo/

# Playwright e2e artifacts (regenerated on every run — never commit)
test-results/
playwright-report/
playwright/.cache/

# Next.js generated type shim (regenerated on every build — never commit)
next-env.d.ts

# Environment files — secrets must never be committed (V14)
.env
.env.*
!.env.example

# Logs
*.log

# OS / editor cruft
.DS_Store

# Local Claude Code settings (machine-specific; never commit)
.claude/settings.local.json

# Transient GSD agent worktrees
.claude/worktrees/
