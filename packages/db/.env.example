# @imbau/db environment example — copy to `.env` and fill in real values locally.
# `.env`/`.env.*` are gitignored (except this file); never commit real passwords.
# Real secret encryption (SOPS/age) is phase 4 (INFRA-03) — placeholders only here.
#
# Three connection strings, one per Postgres role (D-04 / D-06). All point at the
# Compose Postgres (host 5432, db `imbau`). The owner/migration role is `imbau`;
# `app_authenticated` and `anon` are created by the RLS migration (plan 02-02).

NODE_ENV=development

# Owner/migration role — runs DDL via drizzle-kit (db:generate / db:migrate).
DATABASE_URL=postgres://imbau:dev@localhost:5432/imbau

# Runtime role — app queries via withTenant(); NOSUPERUSER, NOBYPASSRLS, no ownership.
DATABASE_APP_URL=postgres://app_authenticated:dev@localhost:5432/imbau

# Public read-only role — withAnon(); sees only estado='publicado' projects.
DATABASE_ANON_URL=postgres://anon:dev@localhost:5432/imbau
