# Staging runtime secret KEY CONTRACT (INFRA-03) — NAMES ONLY, NO REAL VALUES.
#
# This file documents every secret the staging deploy needs so it stays
# reproducible. In Task 2 you fill these keys with REAL values into a throwaway
# plaintext temp, encrypt it to secrets/staging.enc.yaml via `sops -e`, then
# delete the temp. The example values shown below are NON-SENSITIVE defaults
# (hostnames/URLs/enums) only where the value is structural, never a credential.
#
# Variable names are the authoritative ones validated by the apps' env presets
# (packages/config/env/presets.ts: dbEnv, redisEnv, authEnv, sentryEnv, lokiEnv).
#
# ── NOT in this file (CI / VPS secrets, plan 04-06) ─────────────────────────
# These are GitHub Actions / VPS secrets, NOT staging runtime env, so they are
# deliberately excluded from staging.enc.yaml:
#   SENTRY_AUTH_TOKEN  — build-time source-map upload (turbo passThroughEnv)
#   GHCR_PAT           — registry auth for docker pull on the VPS
#   VPS_SSH_KEY        — SSH deploy key (Actions secret)
#   SOPS_AGE_KEY       — age private key (Actions secret + VPS keyfile)
# ────────────────────────────────────────────────────────────────────────────

# ── Postgres + role-split connection strings (D-04 / D-06) ──────────────────
POSTGRES_PASSWORD=          # superuser/owner bootstrap password for the postgres image
APP_DB_PASSWORD=            # password for the app_authenticated role (bootstrap-roles.sql, 04-06)
ANON_DB_PASSWORD=           # password for the anon role (bootstrap-roles.sql, 04-06)
DATABASE_URL=               # owner/migration role (imbau) — DDL via drizzle-kit
DATABASE_APP_URL=           # app_authenticated role — runtime queries (D-04)
DATABASE_ANON_URL=          # anon role — public published-only read path (D-06)

# ── Redis (BullMQ / cache) ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Better Auth + transactional email (AUTH-03 / D-09) ──────────────────────
BETTER_AUTH_SECRET=         # signing secret, 32+ chars
BETTER_AUTH_URL=https://panel.staging.tours.andescode.com.ar
RESEND_API_KEY=             # Resend API key (required in staging)
INVITE_FROM=                # verified Resend sender address

# ── Sentry runtime DSNs (OBS-01) ────────────────────────────────────────────
SENTRY_DSN=                 # server/worker DSN
NEXT_PUBLIC_SENTRY_DSN=     # browser DSN
NEXT_PUBLIC_APP_ENV=staging

# ── Loki log shipping (OBS-02 / D-04) ───────────────────────────────────────
LOKI_URL=http://loki:3100
LOKI_BASIC_AUTH=            # optional — JSON string, only for the Grafana Cloud fallback
