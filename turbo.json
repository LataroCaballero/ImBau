{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "passThroughEnv": [
        "SKIP_ENV_VALIDATION",
        "NEXT_PUBLIC_APP_ENV",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "SENTRY_AUTH_TOKEN",
        "NEXT_PUBLIC_SENTRY_DSN"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"],
      "passThroughEnv": [
        "TEST_DATABASE_URL",
        "TEST_DATABASE_APP_URL",
        "TEST_DATABASE_ANON_URL",
        "DATABASE_URL",
        "DATABASE_APP_URL",
        "DATABASE_ANON_URL",
        "REDIS_URL",
        "NODE_ENV",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
